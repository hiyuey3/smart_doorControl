/* pages/login/index.wxss */
/* 身份鉴权页样式 - 专业极简风格 */

.login-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #F8FAFC;
  padding: 80rpx 40rpx 40rpx 40rpx;
  box-sizing: border-box;
  justify-content: space-between;
}

/* 页面标题样式 */
.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #0F172A;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #64748B;
  display: block;
  letter-spacing: 0.5rpx;
  font-weight: 400;
}

/* 登录区块 */
.login-section {
  width: 100%;
  max-width: 680rpx;
  align-self: center;
  flex: 1;
}

/* 表单样式 */
.form-container {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 48rpx 36rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
  margin-bottom: 32rpx;
}

.form-item {
  margin-bottom: 36rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #334155;
  margin-bottom: 16rpx;
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

/* 密码输入框包装器 */
.password-input-wrapper {
  position: relative;
  width: 100%;
}

.form-input {
  width: 100%;
  height: 96rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  color: #1E293B;
  box-sizing: border-box;
  border: 2rpx solid #E2E8F0;
  display: block;
  transition: all 0.25s ease;
}

.password-input {
  padding-right: 80rpx;
}

.form-input:focus {
  background: #ffffff;
  border-color: #007AFF;
  outline: none;
  box-shadow: 0 0 0 4rpx rgba(0, 122, 255, 0.08);
}

/* 密码可见性切换 */
.password-toggle {
  position: absolute;
  right: 24rpx;
  top: 50%;
  transform: translateY(-50%);
  padding: 8rpx 12rpx;
  cursor: pointer;
}

.toggle-text {
  font-size: 24rpx;
  color: #007AFF;
  transition: color 0.2s;
  font-weight: 500;
}

.password-toggle:active .toggle-text {
  color: #0051D5;
}

/* 密码提示 */
.password-hint {
  text-align: right;
  margin: 16rpx 0 24rpx 0;
}

.password-hint text {
  font-size: 24rpx;
  color: #64748B;
  letter-spacing: 0.5rpx;
}

/* 按钮样式 */
.login-button {
  width: 100% !important;
  height: 96rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: 600;
  transition: all 0.25s ease;
  letter-spacing: 1rpx;
  margin: 0;
  padding: 0;
}

/* 主登录按钮 */
.primary-btn {
  background: #007AFF;
  color: #ffffff;
  border: none;
  box-shadow: 0 2rpx 8rpx rgba(0, 122, 255, 0.2);
}

/* 微信登录按钮 - 镂空样式 */
.secondary-btn {
  background: #ffffff;
  color: #07C160;
  border: 2rpx solid #07C160;
  box-shadow: none;
  margin-top: 0;
}

/* 按钮点击效果 */
.button-hover {
  opacity: 0.85;
  transform: translateY(1rpx);
}

/* 分隔线 */
.divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 32rpx 0;
  width: 100%;
}

.divider::before,
.divider::after {
  content: '';
  flex: 1;
  height: 1rpx;
  background: #E2E8F0;
}

.divider text {
  padding: 0 20rpx;
  font-size: 24rpx;
  color: #94A3B8;
  font-weight: 400;
}

/* 页脚帮助文字 */
.footer-help {
  text-align: center;
  padding: 32rpx 0;
  margin-top: auto;
}

.footer-help text {
  font-size: 24rpx;
  color: #94A3B8;
  letter-spacing: 0.5rpx;
}
