/* pages/users/manage.wxss */
/* 成员管理 + 审批页面 - 纯原生样式 */

.page-container {
  width: 100%;
  min-height: 100vh;
  background-color: #f7f8fa;
}

.page-header {
  padding: 32rpx 30rpx 20rpx;
  background-color: #ffffff;
}

.page-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

/* 标签页导航栏 */
.tab-bar {
  display: flex;
  background-color: #ffffff;
  border-bottom: 1rpx solid #ebedf0;
}

.tab-item {
  position: relative;
  flex: 1;
  padding: 24rpx 0;
  text-align: center;
}

.tab-text {
  font-size: 30rpx;
  color: #666;
}

.tab-active .tab-text {
  color: #1989fa;
  font-weight: 500;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: #1989fa;
  border-radius: 2rpx;
}

/* 徽章 */
.badge {
  position: absolute;
  top: 16rpx;
  right: 50rpx;
  min-width: 32rpx;
  height: 32rpx;
  line-height: 32rpx;
  padding: 0 8rpx;
  background-color: #ff4c4c;
  color: #ffffff;
  font-size: 20rpx;
  text-align: center;
  border-radius: 16rpx;
}

/* 标签页内容 */
.tab-content {
  padding: 20rpx;
}

/* 成员列表样式 */
.member-list {
  padding-bottom: 120rpx;
}

.member-item {
  background-color: #ffffff;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.member-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.member-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

.member-role {
  font-size: 24rpx;
  color: #999999;
}

.member-actions {
  display: flex;
  align-items: center;
}

.delete-btn {
  font-size: 28rpx;
  color: #ff4c4c;
  padding: 10rpx 20rpx;
}

/* 审批列表样式 */
.application-list {
  padding-bottom: 40rpx;
}

/* 申请卡片 */
.application-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.user-id {
  font-size: 24rpx;
  color: #999;
}

/* 状态徽章 */
.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-pending {
  background-color: #fff9e6;
  color: #ff9800;
}

/* 卡片主体 */
.card-body {
  padding: 24rpx 30rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.info-row:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  min-width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  flex: 1;
}

.mac-address {
  font-family: 'Courier New', monospace;
  color: #1989fa;
}

.time {
  color: #999;
  font-size: 26rpx;
}

/* 卡片底部 - 操作按钮 */
.card-footer {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
}

.card-footer .action-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  border-radius: 0;
}

.card-footer .action-btn::after {
  border: none;
}

.reject-btn {
  background-color: transparent;
  color: #ff4c4c;
  border-right: 1rpx solid #f0f0f0;
}

.approve-btn {
  background-color: transparent;
  color: #52c41a;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  color: #999999;
  font-size: 28rpx;
}

/* 底部操作栏 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #ffffff;
  border-top: 1rpx solid #ebedf0;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.action-btn {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  border: none;
}

.action-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #1989fa 0%, #0c6edb 100%);
  color: #ffffff;
}