<view class="page-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="page-title">成员管理</text>
  </view>

  <!-- 标签页切换 -->
  <view class="tab-bar">
    <view 
      class="tab-item {{currentTab === 0 ? 'tab-active' : ''}}" 
      bindtap="switchTab" 
      data-index="0"
    >
      <text class="tab-text">成员列表</text>
    </view>
    <view 
      class="tab-item {{currentTab === 1 ? 'tab-active' : ''}}" 
      bindtap="switchTab" 
      data-index="1"
    >
      <text class="tab-text">待审批</text>
      <view wx:if="{{pendingCount > 0}}" class="badge">{{pendingCount}}</view>
    </view>
  </view>

  <!-- 成员列表标签页 -->
  <view class="tab-content" wx:if="{{currentTab === 0}}">
    <view class="member-list">
      <view wx:for="{{members}}" wx:key="id" class="member-item" bindtap="viewMemberDetail" data-member="{{item}}">
        <view class="member-info">
          <text class="member-name">{{item.name}}</text>
          <text class="member-role">{{item.role}}</text>
        </view>
        <view class="member-actions">
          <text class="delete-btn" catchtap="deleteMember" data-member="{{item}}">删除</text>
        </view>
      </view>
      
      <view wx:if="{{members.length === 0}}" class="empty-state">
        <text class="empty-text">暂无成员数据</text>
      </view>
    </view>

    <view class="bottom-actions">
      <button class="action-btn primary-btn" bindtap="addNewMember">添加新成员</button>
    </view>
  </view>

  <!-- 审批列表标签页 -->
  <view class="tab-content" wx:if="{{currentTab === 1}}">
    <view class="application-list">
      <!-- 循环渲染申请卡片 -->
      <view 
        class="application-card" 
        wx:for="{{applications}}" 
        wx:key="id"
        wx:for-item="app"
      >
        <view class="card-header">
          <view class="user-info">
            <text class="user-name">{{app.user_name || app.username}}</text>
            <text class="user-id">（{{app.username}}）</text>
          </view>
          <view class="status-badge status-pending">待审批</view>
        </view>

        <view class="card-body">
          <view class="info-row">
            <text class="info-label">设备：</text>
            <text class="info-value">{{app.device_name || app.device_room || app.device_mac}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">MAC：</text>
            <text class="info-value mac-address">{{app.device_mac}}</text>
          </view>
          <view class="info-row" wx:if="{{app.reason}}">
            <text class="info-label">理由：</text>
            <text class="info-value">{{app.reason}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">申请时间：</text>
            <text class="info-value time">{{app.created_at}}</text>
          </view>
        </view>

        <view class="card-footer">
          <button 
            class="action-btn reject-btn" 
            bindtap="handleReject" 
            data-id="{{app.id}}"
            data-name="{{app.user_name || app.username}}"
          >
            拒绝
          </button>
          <button 
            class="action-btn approve-btn" 
            bindtap="handleApprove" 
            data-id="{{app.id}}"
            data-name="{{app.user_name || app.username}}"
          >
            同意
          </button>
        </view>
      </view>

      <!-- 空状态 -->
      <view wx:if="{{applications.length === 0}}" class="empty-state">
        <text class="empty-text">暂无待审批申请</text>
      </view>
    </view>
  </view>
</view>